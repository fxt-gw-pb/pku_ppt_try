# LLM provider: deepseek | mock
LLM_PROVIDER=mock

# DeepSeek API — only required when LLM_PROVIDER=deepseek.
# Real keys live ONLY in this file (after `cp .env.example .env`) or in the
# backend host's environment variables. Never commit .env, never paste a key
# into frontend JS/HTML/README/commits.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Pipeline limits and paths (relative to repo root)
MAX_INPUT_CHARS=30000
OUTPUT_DIR=outputs
JOB_DIR=data/jobs

# Backend bind (FastAPI / Uvicorn)
HOST=127.0.0.1
PORT=8787
